# Environment variables required by docker-compose.staging.yaml.
# Add these in the Coolify UI under "Environment Variables" for the resource.
# Do NOT commit real secrets to git; this file documents the required keys only.

# ---- Database (used by both mysql + php services) ----
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# ---- WordPress ----
# Public URL of the site. Must match the domain configured for nginx in Coolify.
WORDPRESS_URL=https://una.justusdeitert.de
WORDPRESS_TITLE=Una Moehrke
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=change-me-strong-password
WORDPRESS_ADMIN_EMAIL=admin@justusdeitert.de
WORDPRESS_THEME=una-moehrke-theme

# Disable plugin/theme installs from the admin UI (recommended).
WP_DISALLOW_FILE_MODS=1
WP_DEBUG=0

# ---- Theme runtime ----
FULLPAGE_LICENSE_KEY=

# ---- WordPress salts ----
# Generate fresh values at: https://api.wordpress.org/secret-key/1.1/salt/
# (use only the values, not the define() lines)
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=
